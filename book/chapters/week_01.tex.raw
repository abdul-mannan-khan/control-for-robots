\hypertarget{key-equations-to-remember}{%
\subsubsection{Key Equations to Remember}\label{key-equations-to-remember}}

\begin{longtable}[]{@{}ll@{}}
\toprule\noalign{}
Equation & Description \\
\midrule\noalign{}
\endhead
\bottomrule\noalign{}
\endlastfoot
\textbackslash(M(q)\textbackslash ddot\{q\} + C(q,\textbackslash dot\{q\})\textbackslash dot\{q\} + G(q) = \textbackslash tau\textbackslash) & Robot dynamics (Euler--Lagrange) \\
\textbackslash(\textbackslash tau = M(q){[}\textbackslash ddot\{q\}\_d + K\_D\textbackslash dot\{e\} + K\_P e{]} + C\textbackslash dot\{q\} + G\textbackslash) & Computed torque control law \\
\textbackslash(\textbackslash ddot\{e\} + K\_D\textbackslash dot\{e\} + K\_P e = 0\textbackslash) & Closed-loop error dynamics (perfect model) \\
\textbackslash(V = \textbackslash tfrac\{1\}\{2\}\textbackslash dot\{e\}\^{}T M \textbackslash dot\{e\} + \textbackslash tfrac\{1\}\{2\}e\^{}T K\_P e\textbackslash) & Lyapunov function \\
\textbackslash(\textbackslash dot\{V\} = -\textbackslash dot\{e\}\^{}T K\_D \textbackslash dot\{e\} \textbackslash leq 0\textbackslash) & Lyapunov derivative (guarantees stability) \\
\end{longtable}

