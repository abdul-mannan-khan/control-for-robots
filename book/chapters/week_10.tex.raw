parameters={[}\{{\textquotesingle rate\textquotesingle{}}: 250.0, {\textquotesingle kp\_roll\textquotesingle{}}: 6.0\}{]},
),
{\# Rate controller (inner loop, 500 Hz)}
Node(
package={\textquotesingle quadrotor\_control\textquotesingle{}},
